# RefCheck AI — Environment Variables
# Copy this file to .env and fill in your keys

# Get yours at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# The Claude (Anthropic) API is called server-side via the Vite proxy.
# No ANTHROPIC_API_KEY needed in the frontend — add it to your backend/server if deploying.
# For local dev, the proxy in vite.config.ts forwards /api/anthropic → api.anthropic.com
# and injects the key from this variable:
ANTHROPIC_API_KEY=your_anthropic_api_key_here
