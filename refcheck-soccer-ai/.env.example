# RefCheck AI - Environment Variables
# Copy this file to .env and fill in your OpenAI key.

# Required for live video analysis.
# The Vite dev server injects this into the local /api/openai proxy.
OPENAI_API_KEY=""

# Optional. Defaults to gpt-4o.
# gpt-4o is stronger for difficult visual calls; gpt-4o-mini is cheaper.
VITE_OPENAI_MODEL=gpt-4o
